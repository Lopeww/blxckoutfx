{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "icon": "${mod_icon}",
    "authors": [
        "${mod_author}"
    ],
    "license": "${license}",
    "environment": "client",
    "entrypoints": {
        "client": [
            "com.lopew.blxckoutfx.fabric.BlxckoutFXFabric"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-api": "*",
        "minecraft": "${minecraft_version}",
        "java": ">=${java_version}"
    }
}
  
